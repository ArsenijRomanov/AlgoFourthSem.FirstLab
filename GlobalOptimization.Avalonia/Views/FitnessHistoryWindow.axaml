<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:GlobalOptimization.Avalonia.Controls"
        x:Class="GlobalOptimization.Avalonia.Views.FitnessHistoryWindow"
        Width="900"
        Height="580"
        MinWidth="720"
        MinHeight="420"
        Title="График лучшего фитнеса"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*" Margin="16">
    <StackPanel Grid.Row="0" Margin="0,0,0,12">
      <TextBlock FontSize="18" FontWeight="SemiBold" Text="История лучшего фитнеса" />
    </StackPanel>

    <controls:FitnessChartControl Grid.Row="1" Points="{Binding History}" />
  </Grid>
</Window>
